veteran_power_fact=100,105,110,115
veteran_base_raise_chance=50,33,20,0
veteran_work_raise_chance=0,0,0,0
veteran_move_bonus=0,0,0,0
flags="HasNoZOC","IgZOC","NonMil","Provoking","Diplomat","Spy"
roles="DiplomatStartunit"
helptext="A Spy is more skilled in the arts of espionage than her Diplomat predecessor.","She can perform all the functions of the Diplomat. Refer to the Diplomat entry for more details. Unlike a Diplomat, a Spy may also survive an operation in a foreign city and become more experienced as a result. Spies are also more effective than Diplomats at defending cities against foreign Diplomats and Spies.","A Spy can also be used to:\n\n - sabotage an enemy unit reducing its hitpoints to half, if it is alone on a tile and the players are at war;\n - poison the water supply of an enemy city (reducing the population by one);\n - steal specific technology, with a reduced chance of success;\n - steal further technologies from a city which has already been stolen from. Cities become more resistant each time they are stolen from;\n - sabotage predetermined city targets (with a reduced chance of success).","A Spy that survives the more aggressive actions (sabotage, theft, inciting rebellion, and poisoning) escapes to the safety of the nearest friendly city.","Spies built under Communist or Federation governments will start at the first veteran level (handler)."

[unit_49]
name=_("Caravan")
